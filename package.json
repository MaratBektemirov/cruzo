{
  "name": "cruzo",
  "version": "0.9.2",
  "description": "Zero-dependency reactive framework with an expression VM",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ui-components/input": {
      "types": "./dist/ui-components/input/input.component.d.ts",
      "default": "./dist/ui-components/input.js"
    },
    "./ui-components/button-group": {
      "types": "./dist/ui-components/button-group/button-group.component.d.ts",
      "default": "./dist/ui-components/button-group.js"
    },
    "./ui-components/router-link": {
      "types": "./dist/ui-components/router-link/router-link.d.ts",
      "default": "./dist/ui-components/router-link.js"
    },
    "./ui-components/select": {
      "types": "./dist/ui-components/select/select.component.d.ts",
      "default": "./dist/ui-components/select.js"
    },
    "./ui-components/spinner": {
      "types": "./dist/ui-components/spinner/spinner.component.d.ts",
      "default": "./dist/ui-components/spinner.js"
    },
    "./ui-components/upload": {
      "types": "./dist/ui-components/upload/upload.component.d.ts",
      "default": "./dist/ui-components/upload.js"
    },
    "./ui-components/modal": {
      "types": "./dist/ui-components/modal/modal.component.d.ts",
      "default": "./dist/ui-components/modal.js"
    },
    "./ui-components/button-group.css": "./dist/ui-components/button-group.css",
    "./ui-components/input.css": "./dist/ui-components/input.css",
    "./ui-components/modal.css": "./dist/ui-components/modal.css",
    "./ui-components/select.css": "./dist/ui-components/select.css",
    "./ui-components/spinner.css": "./dist/ui-components/spinner.css",
    "./ui-components/upload.css": "./dist/ui-components/upload.css",
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build:lib": "vite build",
    "copy:css": "node scripts/copy-ui-css.mjs",
    "build:types": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.ui.json",
    "build": "npm run build:lib && npm run copy:css && npm run build:types",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "20.0.0",
    "typed-css-modules": "0.9.0",
    "typescript": "5.0.0",
    "vite": "6.0.0"
  }
}
